{
  "task-runners": [
    {
      "runner-type": "python",
      "workdir": "/home/runner",
      "command": "/opt/runners/task-runner-python/.venv/bin/python",
      "args": ["-I", "-B", "-X", "disable_remote_debug", "-m", "src.main"],
      "env-overrides": {
        "PYTHONPATH": "/opt/runners/task-runner-python",
        "N8N_RUNNERS_STDLIB_ALLOW": "datetime",
        "N8N_RUNNERS_EXTERNAL_ALLOW": "pandas,openpyxl,pptx",
        "N8N_RUNNERS_BUILTINS_DENY": ""
      }
    }
  ]
}
